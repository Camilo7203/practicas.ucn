# API Configuration
VITE_API_URL=https://api-app.loophack.ai/api
VITE_API_TIMEOUT=10000

# App Configuration
VITE_APP_NAME=LoopHack
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="LoopHack Frontend Application"

# Authentication
VITE_TOKEN_EXPIRY_WARNING_MINUTES=5
VITE_AUTO_LOGOUT_MINUTES=1

# Development
VITE_ENABLE_MOCK_API=false
VITE_LOG_LEVEL=info
VITE_ENABLE_REDUX_DEVTOOLS=true

# Features
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_AI_AGENTS=true
VITE_ENABLE_DARK_MODE=true

# External Services
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# Facebook Integration for WhatsApp Embedded Signup
# Get these from https://developers.facebook.com/apps/
VITE_FACEBOOK_APP_ID=your-facebook-app-id-here
# Configuration ID from Facebook Login for Business > Configurations
VITE_FACEBOOK_CONFIG_ID=your-configuration-id-here

